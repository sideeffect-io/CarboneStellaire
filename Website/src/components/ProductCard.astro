---
import { shouldShowProductPrice, type Product } from "@/lib/catalog";
import { formatPrice, productPath, type Locale } from "@/lib/i18n";

interface Props {
  product: Product;
  locale: Locale;
}

const { product, locale } = Astro.props;
const image = product.images[0];
const showPrice = shouldShowProductPrice(product);
---

<article class:list={["product-card", !showPrice && "product-card--price-hidden"]} data-reveal>
  <a href={productPath(locale, product.handle)} aria-label={product.title}>
    <figure>
      <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
    </figure>
    <div class="product-card__body">
      <h3>{product.title}</h3>
      {showPrice && <p>{formatPrice(product.price, locale)}</p>}
    </div>
  </a>
</article>
