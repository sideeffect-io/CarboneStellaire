---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { contactPath, homePath, ui } from "@/lib/i18n";

const locale = "en";
const copy = ui[locale].contact;
---

<BaseLayout title={copy.thanksTitle} description={copy.thanksBody} locale={locale} alternatePath="/merci/">
  <section class="thanks-page" data-reveal>
    <p class="eyebrow">Carbone Stellaire</p>
    <h1>{copy.thanksTitle}</h1>
    <p>{copy.thanksBody}</p>
    <div class="hero__actions">
      <a class="button button--primary" href={homePath(locale)}>Home</a>
      <a class="button button--ghost" href={contactPath(locale)}>New message</a>
    </div>
  </section>
</BaseLayout>
