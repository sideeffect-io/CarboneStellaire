---
import Carousel from "@/components/Carousel.astro";
import CategoryBand from "@/components/CategoryBand.astro";
import ProductGrid from "@/components/ProductGrid.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { carouselImages, getFeaturedProducts, siteContent } from "@/lib/catalog";
import { contactPath, ui } from "@/lib/i18n";

const locale = "fr";
const copy = ui[locale];
const sections = siteContent[locale];
const story = sections[0];
const process = sections[1];
const workshop = sections[2];
const featured = getFeaturedProducts(locale);
---

<BaseLayout
  title="Carbone Stellaire"
  description="Couteaux artisanaux forgés à la main dans le nord Cotentin par Carbone Stellaire."
  locale={locale}
  alternatePath="/en/"
>
  <section class="hero" style={`--hero-image: url('${carouselImages[0].src}')`}>
    <div class="hero__shade"></div>
    <div class="hero__content">
      <p class="eyebrow">{copy.hero.kicker}</p>
      <h1>Carbone Stellaire</h1>
      <p class="hero__headline">{copy.hero.headline}</p>
      <div class="hero__actions">
        <a class="button button--primary" href="#ranges">{copy.hero.primary}</a>
        <a class="button button--ghost" href={contactPath(locale)}>{copy.hero.secondary}</a>
      </div>
    </div>
  </section>

  <section class="section section--intro" data-reveal>
    <div class="section__label">{story.title}</div>
    <div class="rich-text" set:html={story.html} />
  </section>

  <section class="section" id="ranges">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">{copy.sections.catalog}</p>
      <h2>{copy.sections.ranges}</h2>
      <p>{copy.sections.rangesIntro}</p>
    </div>
    <CategoryBand locale={locale} />
  </section>

  <section class="section split-section" id="process">
    <div data-reveal>
      <p class="eyebrow">{copy.sections.process}</p>
      <h2>{process.title}</h2>
      <div class="rich-text" set:html={process.html} />
    </div>
    <figure class="split-section__media" data-reveal>
      <img src={carouselImages[2].src} alt="Lame forgée brute" loading="lazy" decoding="async" />
    </figure>
  </section>

  <section class="section split-section split-section--reverse" id="atelier">
    <figure class="split-section__media" data-reveal>
      <img src={carouselImages[5].src} alt="Forge Carbone Stellaire" loading="lazy" decoding="async" />
    </figure>
    <div data-reveal>
      <p class="eyebrow">{copy.sections.workshop}</p>
      <h2>{workshop.title}</h2>
      <div class="rich-text" set:html={workshop.html} />
    </div>
  </section>

  <section class="section section--wide">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">{copy.sections.carousel}</p>
      <h2>Matière, feu, finition</h2>
    </div>
    <Carousel locale={locale} />
  </section>

  <section class="section">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">{copy.sections.selected}</p>
      <h2>Quelques pièces</h2>
    </div>
    <ProductGrid products={featured} locale={locale} />
  </section>

  <section class="final-cta" data-reveal>
    <p class="eyebrow">Sur mesure</p>
    <h2>Une lame commence par une intention.</h2>
    <a class="button button--primary" href={contactPath(locale)}>{copy.sections.contactCta}</a>
  </section>
</BaseLayout>
